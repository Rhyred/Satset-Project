# Auto detect text files and normalize line endings to LF
* text=auto

# Scripts - Unix line endings
/mvnw text eol=lf
/mvnw.* text eol=lf
*.sh text eol=lf

# Windows files - Windows line endings
*.cmd text eol=crlf
*.bat text eol=crlf
*.ps1 text eol=crlf

# Java & Build files
*.java text eol=lf
*.xml text eol=lf
*.properties text eol=lf
*.gradle text eol=lf
pom.xml text eol=lf

# Web files
*.html text eol=lf
*.css text eol=lf
*.js text eol=lf
*.json text eol=lf
*.yaml text eol=lf
*.yml text eol=lf

# Binary files
*.jar binary
*.class binary
*.gif binary
*.ico binary
*.jpg binary
*.jpeg binary
*.png binary
*.gif binary
*.zip binary
*.db binary
*.sqlite binary

# Documentation
*.md text eol=lf
*.markdown text eol=lf
LICENSE text eol=lf
CONTRIBUTING text eol=lf
